---
interface Props {
  years: number[];
  currentYear: number;
}

const { years, currentYear } = Astro.props;
---

<header class="bg-green-800 text-white shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Left: Icon + Title -->
      <div class="flex items-center gap-3">
        <img
          src="/logo.svg"
          alt="GTA West Clublink League logo"
          class="h-10 w-10 object-contain"
          onerror="this.style.display='none'"
        />
        <a href="/" class="text-xl font-bold tracking-tight hover:text-green-200 transition-colors">
          GTA West Clublink League
        </a>
      </div>

      <!-- Right: Year selector -->
      {
        years.length > 1 && (
          <nav class="flex items-center gap-2" aria-label="Year navigation">
            {years.map((y) => (
              <a
                href={`/${y}`}
                class={`text-sm font-medium px-3 py-1.5 rounded-md transition-colors ${
                  y === currentYear
                    ? "bg-green-600 text-white"
                    : "text-green-200 hover:bg-green-700 hover:text-white"
                }`}
              >
                {y}
              </a>
            ))}
          </nav>
        )
      }
      {
        years.length === 1 && (
          <a href={`/${currentYear}`} class="text-sm font-medium text-green-200 hover:text-white transition-colors">
            {currentYear}
          </a>
        )
      }
    </div>
  </div>
</header>

